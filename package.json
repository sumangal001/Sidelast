{
  "name": "stylefix",
  "version": "1.0.0",
  "description": "Floating Windows desktop assistant that fixes selected text and learns your writing style",
  "main": "dist/main/index.js",
  "author": "",
  "license": "MIT",
  "scripts": {
    "build": "tsc",
    "watch": "tsc -w",
    "start": "npm run build && electron .",
    "dev": "concurrently -k \"npm run watch\" \"wait-on dist/main/index.js && electron .\"",
    "pack": "npm run build && electron-builder --dir",
    "dist": "npm run build && electron-builder",
    "rebuild": "electron-rebuild -f -w uiohook-napi,better-sqlite3",
    "postinstall": "electron-builder install-app-deps"
  },
  "build": {
    "appId": "com.stylefix.app",
    "productName": "StyleFix",
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**/*",
      "src/renderer/**/*",
      "package.json"
    ],
    "asar": true,
    "asarUnpack": [
      "**/*.node"
    ],
    "npmRebuild": false,
    "buildDependenciesFromSource": false,
    "win": {
      "target": [
        "nsis"
      ],
      "signAndEditExecutable": false
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "StyleFix"
    }
  },
  "devDependencies": {
    "@electron/rebuild": "^4.2.0",
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^22.10.0",
    "concurrently": "^9.1.0",
    "electron": "^33.2.0",
    "electron-builder": "^25.1.8",
    "typescript": "^5.7.2",
    "wait-on": "^8.0.1"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.111.0",
    "better-sqlite3": "^12.11.1",
    "electron-store": "^8.2.0",
    "uiohook-napi": "^1.5.5"
  }
}
